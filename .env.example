# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (required for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CRON authentication (min 16 chars, optional in dev)
CRON_SECRET=your-cron-secret-min-16-chars

# Encryption (min 32 chars, optional in dev, required in prod)
# Protege les API keys tenants stockees en DB
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# Odoo - push factures/avoirs et pull paiements
# Si une seule variable manque, le client retombe sur un stub (no-op)
ODOO_URL=https://your-tenant.odoo.com
ODOO_DB=your-db-name
ODOO_USERNAME=integration@example.com
ODOO_API_KEY=your-odoo-api-key

# Resend - envoi emails (factures, relances, digests)
# Si absent: emails skipped + log warning
RESEND_API_KEY=re_your-resend-key

# Email override (staging/demo) - redirige TOUS les emails sortants
# vers cette adresse, prefixe sujet "[DEMO -> original@x.com]"
# NE JAMAIS positionner en prod reelle
EMAIL_OVERRIDE=test@example.com

# Sentry - error tracking (no-op si DSN absent)
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Upstash Redis - rate limit auth (auto-provisionne par Vercel Marketplace)
# Fail-open si manquant
UPSTASH_REDIS_REST_KV_REST_API_URL=https://...
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=...

# Giphy - recherche GIF dans le chat equipe (optionnel)
GIPHY_API_KEY=your-giphy-key

# Avatar freeze unlock secret - easter egg (optionnel)
AVATAR_UNLOCK_SECRET=your-20-char-secret
